{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(vercel *)",
      "Bash(npm *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "powershell -NoProfile -File \"D:/AppCDP/mda-cdp/.claude/hooks/mark-deploy.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "powershell -NoProfile -File \"D:/AppCDP/mda-cdp/.claude/hooks/auto-deploy.ps1\""
          }
        ]
      }
    ]
  }
}
